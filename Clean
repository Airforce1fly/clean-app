.btn-fight .arr{position:absolute;right:22px;top:50%;transform:translateY(-50%);font-size:28px;opacity:.8}
.btn-anticipate{width:100%;margin-top:8px;padding:12px 18px;background:transparent;border:1px dashed var(--brass);color:var(--brass);font-family:var(--mono);font-size:10px;letter-spacing:3px;cursor:pointer;text-align:center;transition:all .15s}
.card{background:var(--panel);border:1px solid var(--border);padding:18px 20px;margin-top:12px}
.card-hd{font-family:var(--mono);font-size:9px;letter-spacing:3px;text-transform:uppercase;margin-bottom:10px}
.card-hr{border:none;border-top:1px dashed var(--border);margin:16px 0}
