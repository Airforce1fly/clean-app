#ceremony{position:fixed;inset:0;z-index:100;display:none}
#ceremony.on{display:flex;align-items:center;justify-content:center}
#flash{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);z-index:200;pointer-events:none}
#aar{position:fixed;bottom:24px;left:16px;right:16px;z-index:180;pointer-events:none;display:none}
#loot{position:fixed;bottom:24px;left:16px;right:16px;z-index:185;pointer-events:none;display:none}
#particles{position:fixed;inset:0;z-index:190;pointer-events:none}
