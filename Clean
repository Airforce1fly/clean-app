.trigger-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.trigger-btn{padding:16px 12px;background:var(--panel);border:1px solid var(--border);color:var(--paper);font-family:var(--display);font-size:16px;cursor:pointer;text-align:center;transition:all .15s}
.trigger-btn:active{background:var(--panelLift);border-color:var(--brass)}
.trigger-btn.unknown{grid-column:1/-1;font-size:14px;color:var(--faded);font-style:italic}
.briefing-card-inner{padding:18px 20px;background:var(--panelLift);border:1px solid var(--brass);text-align:center;animation:briefIn .3s ease-out}
