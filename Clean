.anticipation-bar{width:100%;height:4px;background:var(--border);margin-top:4px;overflow:hidden}
.anticipation-fill{height:100%;background:var(--brass);transition:width 1s linear}
.evo-bar-wrap{display:flex;align-items:center;gap:8px;margin-top:6px}
.evo-bar-bg{flex:1;height:4px;background:var(--border);overflow:hidden}
.evo-bar-fill{height:100%;background:var(--brass);transition:width .5s}
.evo-arrow{font-family:var(--mono);font-size:9px;color:var(--faded);min-width:40px;text-align:right}
.modal-page{position:fixed;inset:0;background:rgba(10,8,6,.97);z-index:60;display:flex;flex-direction:column;padding:24px 16px;overflow-y:auto}
.modal-pop{position:fixed;inset:0;background:rgba(10,8,6,.97);z-index:70;display:flex;align-items:center;justify-content:center;padding:24px 16px}
.modal-card{background:var(--panel);border:1px solid var(--border);padding:28px 24px;max-width:400px;width:100%}
.modal-shake{animation:modalShake .4s ease-out}
@keyframes modalShake{0%,100%{transform:translateX(0)}10%{transform:translateX(-8px)}30%{transform:translateX(8px)}50%{transform:translateX(-4px)}70%{transform:translateX(4px)}90%{transform:translateX(-2px)}}
.ceremony-box{background:rgba(10,8,6,.98);width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;animation:fadeIn .6s}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.ceremony-rank{font-family:var(--display);font-size:52px;color:var(--brass);font-weight:500;animation:popIn .8s cubic-bezier(.175,.885,.32,1.275)}
@keyframes popIn{from{transform:scale(.3);opacity:0}to{transform:scale(1);opacity:1}}
.loadout-slot{background:var(--panel);border:1px solid var(--border);padding:12px 14px;display:flex;justify-content:space-between;align-items:center}
.loadout-slot.empty{border-style:dashed;color:var(--faded)}
.tac-lvl{font-family:var(--mono);font-size:9px;letter-spacing:2px;padding:2px 6px;border-radius:2px}
.tac-lvl.hardened{color:var(--brass);border:1px solid var(--brass)}
.tac-lvl.veteran{color:var(--verde);border:1px solid var(--verde)}
.tac-lvl.elite{color:var(--brass);border:1px solid var(--brass);background:rgba(196,162,97,.1)}
.tac-lvl.standard{color:var(--faded);border:1px solid var(--border)}
.tac-card{background:var(--panelLift);border:1px solid var(--border);padding:14px 16px;cursor:pointer;transition:all .15s}
.tac-card:active{background:var(--panel)}
.tac-card.picked{border-color:var(--brass);background:rgba(196,162,97,.1);animation:tacSlam .3s ease-out}
.tac-card.mastercraft{border-color:var(--brass);box-shadow:0 0 12px rgba(196,162,97,.2)}
@keyframes tacSlam{0%{transform:scale(1.05)}50%{transform:scale(.97)}100%{transform:scale(1)}}
.tac-card .eff{font-family:var(--mono);font-size:8px;letter-spacing:2px;margin-top:6px}
.setup-type-card{padding:16px 14px;background:var(--panel);border:2px solid var(--border);cursor:pointer;text-align:center;transition:all .2s;margin-bottom:10px}
.setup-type-card.selected{border-color:var(--brass);background:var(--panelLift)}
.flex-btwn{display:flex;justify-content:space-between;align-items:center}
.hidden{display:none!important}
.mt-2{margin-top:8px}.mt-3{margin-top:12px}.mt-4{margin-top:16px}.mt-6{margin-top:24px}
.mb-2{margin-bottom:8px}.mb-4{margin-bottom:16px}
input,textarea{outline:none;-webkit-appearance:none;border-radius:0}
input:focus,textarea:focus{border-color:var(--brass)!important}
</style>
