function startEncounter(trig){var e=elapsed(state.data.quitDate,now);var elite=Math.random()<eliteChance();var boss=bossNow(e.th);var intensity=boss?10:(elite?8+Math.floor(Math.random()*3):Math.floor(Math.random()*7)+1);var mods=getEquippedMods();if(mods.indexOf('ironWill')>=0&&elite)intensity=Math.max(1,intensity-2);if(!trig){trig=TRIGGERS[Math.floor(Math.random()*TRIGGERS.length)];var held=state.cravings.filter(function(c){return c.ok&&c.trig&&c.trig!=="RESET";});if(held.length>=3){var tc={};held.forEach(function(c){tc[c.trig]=(tc[c.trig]||0)+1;});var keys=Object.keys(tc);var top=keys[0];for(var i=1;i<keys.length;i++){if(tc[keys[i]]>tc[top])top=keys[i];}if(Math.random()<.6)trig=top;}}var ab=false,at=null;if(state.anticipation&&state.anticipation.expiresAt&&Date.now()<=state.anticipation.expiresAt&&state.anticipation.trigger===trig){ab=true;at=state.anticipation.tactic;state.anticipation.used=true;state.anticipation.expiresAt=0;save();}enc={id:Date.now(),start:Date.now(),intensity:intensity,trig:trig,elite:elite,boss:!!boss,bdata:boss,pick:null,used:null,sec:elite?360:(boss?480:300),breath:0,btxt:"Breathe in",antiBonus:ab,antiTactic:at,breathSlow:mods.indexOf('steadyHands')>=0};if(boss){playSound('boss');buzz([50,50,50,50,50,50]);}else{playSound('encounter');buzz(30);}var at2=allTacs();if(!state.load||state.load.length===0){state.load=at2.slice(0,4).map(function(t){return t.text;});save();}showBriefing(trig,boss);}
