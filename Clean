var AudioCtx=window.AudioContext||window.webkitAudioContext;var audioCtx=null;
function getAudio(){if(!audioCtx)audioCtx=new AudioCtx();return audioCtx;}
function playSound(t){try{var c=getAudio();var n=c.currentTime;var g=c.createGain();g.connect(c.destination);var o;switch(t){case'encounter':o=c.createOscillator();o.type='sawtooth';o.frequency.setValueAtTime(100,n);o.frequency.linearRampToValueAtTime(60,n+.3);g.gain.setValueAtTime(.15,n);g.gain.linearRampToValueAtTime(0,n+.35);o.connect(g);o.start(n);o.stop(n+.35);break;case'tactic':o=c.createOscillator();o.type='sine';o.frequency.setValueAtTime(600,n);o.frequency.linearRampToValueAtTime(800,n+.08);g.gain.setValueAtTime(.1,n);g.gain.linearRampToValueAtTime(0,n+.1);o.connect(g);o.start(n);o.stop(n+.1);break;case'held':o=c.createOscillator();o.type='triangle';o.frequency.setValueAtTime(400,n);o.frequency.setValueAtTime(600,n+.12);g.gain.setValueAtTime(.12,n);g.gain.linearRampToValueAtTime(0,n+.3);o.connect(g);o.start(n);o.stop(n+.3);break;case'boss':o=c.createOscillator();o.type='sawtooth';o.frequency.setValueAtTime(50,n);o.frequency.linearRampToValueAtTime(30,n+.6);g.gain.setValueAtTime(.2,n);g.gain.linearRampToValueAtTime(0,n+.7);o.connect(g);o.start(n);o.stop(n+.7);break;case'slip':o=c.createOscillator();o.type='sine';o.frequency.setValueAtTime(300,n);o.frequency.linearRampToValueAtTime(150,n+.4);g.gain.setValueAtTime(.1,n);g.gain.linearRampToValueAtTime(0,n+.45);o.connect(g);o.start(n);o.stop(n+.45);break;case'promotion':o=c.createOscillator();o.type='triangle';o.frequency.setValueAtTime(500,n);o.frequency.setValueAtTime(700,n+.15);o.frequency.setValueAtTime(900,n+.3);g.gain.setValueAtTime(.1,n);g.gain.linearRampToValueAtTime(0,n+.5);o.connect(g);o.start(n);o.stop(n+.5);break;case'anticipate':o=c.createOscillator();o.type='sine';o.frequency.setValueAtTime(300,n);o.frequency.setValueAtTime(500,n+.15);g.gain.setValueAtTime(.08,n);g.gain.linearRampToValueAtTime(0,n+.25);o.connect(g);o.start(n);o.stop(n+.25);break;case'loot':o=c.createOscillator();o.type='sine';o.frequency.setValueAtTime(800,n);o.frequency.setValueAtTime(1200,n+.1);g.gain.setValueAtTime(.1,n);g.gain.linearRampToValueAtTime(0,n+.2);o.connect(g);o.start(n);o.stop(n+.2);break;}}catch(e){}}
function buzz(p){if(navigator.vibrate)navigator.vibrate(p);}
