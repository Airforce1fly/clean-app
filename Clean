function startAntiTimer(){if(antiTimer)clearInterval(antiTimer);var u=function(){if(!state.anticipation||!state.anticipation.expiresAt)return;var rem=Math.max(0,Math.ceil((state.anticipation.expiresAt-Date.now())/1000));var el=document.getElementById("antiCountdown");var fill=document.getElementById("antiFill");if(el)el.textContent=Math.floor(rem/60)+':'+pad(rem%60);if(fill)fill.style.width=Math.min(100,(rem/900)*100)+"%";if(rem<=0){clearInterval(antiTimer);antiTimer=null;if(view==="dash"&&!modal)rerender();}};u();antiTimer=setInterval(u,1000);}
function openTriggerScreen(mode){var h='<div class="modal-pop"><div class="modal-card"><div class="mono-label brass mb-4">◆ WHAT TRIGGERED IT?</div><div class="trigger-grid">';for(var i=0;i<TRIGGERS.length;i++){h+='<button class="trigger-btn" data-trig="'+TRIGGERS[i]+'">'+TRIGGERS[i]+'</button>';}h+='<button class="trigger-btn unknown" data-trig="random">I don\'t know</button></div><button class="btn btn-ghost mt-4" id="cancelTrig">cancel</button></div></div>';showModals(h);document.getElementById("cancelTrig").addEventListener("click",function(){modal=null;clsModals();rerender();});var btns=document.querySelectorAll(".trigger-btn");for(var j=0;j<btns.length;j++){btns[j].addEventListener("click",function(){var trig=this.dataset.trig;buzz(20);clsModals();if(mode==='anticipate')startAnticipation(trig==='random'?null:trig);else startEncounter(trig==='random'?null:trig);});}}
